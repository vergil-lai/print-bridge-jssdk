{
  "name": "print-bridge-sdk",
  "version": "0.1.3",
  "description": "Browser SDK for connecting Web pages to the local PrintBridge service.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepare": "husky",
    "prepack": "pnpm build",
    "release": "node scripts/release.mjs",
    "release:sdk": "node scripts/release.mjs sdk",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src tests rollup.config.js",
    "lint:fix": "oxlint --fix src tests rollup.config.js",
    "format": "oxfmt --write \"src/**/*\" \"tests/**/*\" rollup.config.js tsconfig.json",
    "format:check": "oxfmt --check \"src/**/*\" \"tests/**/*\" rollup.config.js tsconfig.json",
    "lint-staged": "lint-staged",
    "build": "rollup -c --forceExit",
    "dev": "rollup -c -w",
    "pretest": "pnpm build",
    "test": "vitest run tests && node --test scripts/*.test.mjs"
  },
  "keywords": [
    "printbridge",
    "printing",
    "websocket",
    "sdk"
  ],
  "homepage": "https://github.com/vergil-lai/print-bridge-jssdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vergil-lai/print-bridge-jssdk.git"
  },
  "bugs": {
    "url": "https://github.com/vergil-lai/print-bridge-jssdk/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4",
    "ws": "^8.21.0"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,cts,mts}": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ]
  }
}
